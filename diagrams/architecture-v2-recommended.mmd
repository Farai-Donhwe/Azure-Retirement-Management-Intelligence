---
title: "Azure Retirement Intelligence — Recommended Architecture (Azure WAF-Aligned)"
---
flowchart LR
    %% ═══════════════════════════════════════════════════
    %% AZURE SIGNAL SOURCES
    %% ═══════════════════════════════════════════════════
    subgraph azure ["fa:fa-cloud Microsoft Azure — Signal Sources"]
        direction TB
        advisor_api[/"Azure Advisor API<br/>(Retirement Recs)"/]
        arg[/"Azure Resource Graph<br/>(Cross-Sub Query)"/]
        svc_health["Azure Service Health<br/>(Retirement Alerts)"]
        event_grid{{"Azure Event Grid<br/>(Event Routing)"}}
        svc_health -->|"Publish events"| event_grid
    end

    %% ═══════════════════════════════════════════════════
    %% APPLICATION TIER — Azure Functions
    %% ═══════════════════════════════════════════════════
    subgraph app ["fa:fa-bolt Application Tier — Azure Functions (Python)"]
        direction TB
        fn_sched(["fn-scheduler<br/>Timer Trigger<br/>(Daily/Hourly)"])
        fn_collect["fn-retirement-collector<br/>Service Bus Trigger"]
        fn_analyze["fn-impact-analyzer<br/>Service Bus Trigger"]
        fn_bestprac["fn-best-practice-engine<br/>Service Bus Trigger"]
        fn_agent{{"fn-automation-agent<br/>Service Bus Trigger"}}
        fn_api["fn-dashboard-api<br/>HTTP Trigger"]
    end

    %% ═══════════════════════════════════════════════════
    %% PLATFORM TIER — Messaging
    %% ═══════════════════════════════════════════════════
    subgraph platform ["fa:fa-exchange Platform — Azure Service Bus"]
        direction TB
        sb_collect["queue: retirement-collect"]
        sb_analyze["queue: impact-analyze"]
        sb_bestprac["queue: best-practice"]
        sb_ticket["queue: ticket-dispatch"]
        sb_dlq["Dead-Letter Queue<br/>(Failed Messages)"]
    end

    %% ═══════════════════════════════════════════════════
    %% DATA TIER
    %% ═══════════════════════════════════════════════════
    subgraph data ["fa:fa-database Data Tier"]
        direction TB
        cosmos[("Azure Cosmos DB<br/>(Retirement Intel Store)<br/>Serverless")]
        blob[("Azure Storage<br/>Blob (Reports/Artifacts)")]
    end

    %% ═══════════════════════════════════════════════════
    %% SERVICENOW
    %% ═══════════════════════════════════════════════════
    subgraph snow ["fa:fa-ticket ServiceNow"]
        direction TB
        incident["Incident Module"]
        chg["Change Module<br/>(ITIL/CAB)"]
        cmdb["CMDB<br/>(Apps/Services/Owners)"]
    end

    %% ═══════════════════════════════════════════════════
    %% SECURITY TIER
    %% ═══════════════════════════════════════════════════
    subgraph sec ["fa:fa-shield Security & Identity"]
        direction TB
        entra["Microsoft Entra ID<br/>(Managed Identity)"]
        kv[("Azure Key Vault<br/>(ServiceNow OAuth)")]
    end

    %% ═══════════════════════════════════════════════════
    %% OPERATIONS TIER
    %% ═══════════════════════════════════════════════════
    subgraph ops ["fa:fa-chart-line Operations & Observability"]
        direction TB
        appins["Application Insights"]
        logana["Log Analytics<br/>Workspace"]
        alerts["Azure Monitor Alerts"]
        appins --> logana
        logana --> alerts
    end

    %% ═══════════════════════════════════════════════════
    %% REPORTING
    %% ═══════════════════════════════════════════════════
    subgraph report ["fa:fa-area-chart Reporting"]
        direction TB
        pbi["Power BI Dashboard"]
    end

    %% ═══════════════════════════════════════════════════
    %% PERSONAS
    %% ═══════════════════════════════════════════════════
    ops_eng(["fa:fa-user Cloud Ops / SRE"])
    cam_mgr(["fa:fa-user Change Manager / CAB"])
    app_own(["fa:fa-user Application Owner"])
    fin_ops(["fa:fa-user FinOps"])

    %% ═══════════════════════════════════════════════════
    %% FLOW: Scheduler kicks off pipeline
    %% ═══════════════════════════════════════════════════
    fn_sched -->|"Enqueue collect job"| sb_collect

    %% ═══════════════════════════════════════════════════
    %% FLOW: Collector pulls signals + persists
    %% ═══════════════════════════════════════════════════
    sb_collect -->|"Trigger"| fn_collect
    fn_collect -->|"REST"| advisor_api
    fn_collect -->|"KQL"| arg
    event_grid -->|"Push events"| fn_collect
    fn_collect -->|"Write retirements"| cosmos
    fn_collect -->|"Enqueue analysis"| sb_analyze

    %% ═══════════════════════════════════════════════════
    %% FLOW: Impact Analyzer
    %% ═══════════════════════════════════════════════════
    sb_analyze -->|"Trigger"| fn_analyze
    fn_analyze <-->|"Read/Write impact"| cosmos
    fn_analyze -->|"Resolve owners"| cmdb
    fn_analyze -->|"Enqueue guidance"| sb_bestprac

    %% ═══════════════════════════════════════════════════
    %% FLOW: Best Practice Engine
    %% ═══════════════════════════════════════════════════
    sb_bestprac -->|"Trigger"| fn_bestprac
    fn_bestprac -->|"Write change plans"| cosmos
    fn_bestprac -->|"Enqueue ticket"| sb_ticket

    %% ═══════════════════════════════════════════════════
    %% FLOW: Automation Agent → ServiceNow
    %% ═══════════════════════════════════════════════════
    sb_ticket -->|"Trigger"| fn_agent
    fn_agent -->|"Create Incident"| incident
    fn_agent -->|"Create Change"| chg
    fn_agent -->|"Read tokens"| kv

    %% ═══════════════════════════════════════════════════
    %% FLOW: Dashboard + Reporting
    %% ═══════════════════════════════════════════════════
    fn_api -->|"Query"| cosmos
    fn_api -->|"Serve"| pbi
    cosmos -->|"Direct Query"| pbi

    %% ═══════════════════════════════════════════════════
    %% PERSONA TOUCHPOINTS
    %% ═══════════════════════════════════════════════════
    pbi -.-> ops_eng
    pbi -.-> fin_ops
    chg -.-> cam_mgr
    incident -.-> app_own
    alerts -.->|"PagerDuty/Email"| ops_eng

    %% ═══════════════════════════════════════════════════
    %% SECURITY FLOWS
    %% ═══════════════════════════════════════════════════
    entra -. "Managed Identity" .-> fn_collect
    entra -. "Managed Identity" .-> fn_analyze
    entra -. "Managed Identity" .-> fn_agent
    entra -. "RBAC Reader" .-> arg

    %% ═══════════════════════════════════════════════════
    %% OBSERVABILITY
    %% ═══════════════════════════════════════════════════
    fn_collect -.->|"Telemetry"| appins
    fn_analyze -.->|"Telemetry"| appins
    fn_agent -.->|"Telemetry"| appins
    sb_dlq -.->|"Alert on DLQ"| alerts

    %% ═══════════════════════════════════════════════════
    %% STYLES
    %% ═══════════════════════════════════════════════════
    classDef azureSrc fill:#E6F2FF,stroke:#0078D4,stroke-width:2px,color:#003A6C
    classDef fnNode fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px,color:#1B5E20
    classDef sbNode fill:#E1F5FE,stroke:#0277BD,stroke-width:2px,color:#01579B
    classDef dataNode fill:#FFF9C4,stroke:#F9A825,stroke-width:2px,color:#E65100
    classDef snowNode fill:#FFF3E0,stroke:#E65100,stroke-width:2px,color:#BF360C
    classDef secNode fill:#FCE4EC,stroke:#C62828,stroke-width:2px,color:#B71C1C
    classDef opsNode fill:#F3E5F5,stroke:#7B1FA2,stroke-width:2px,color:#4A148C
    classDef pbiNode fill:#E8EAF6,stroke:#283593,stroke-width:2px,color:#1A237E
    classDef persona fill:#ECEFF1,stroke:#546E7A,stroke-width:1px,color:#263238

    class advisor_api,arg,svc_health,event_grid azureSrc
    class fn_sched,fn_collect,fn_analyze,fn_bestprac,fn_agent,fn_api fnNode
    class sb_collect,sb_analyze,sb_bestprac,sb_ticket,sb_dlq sbNode
    class cosmos,blob dataNode
    class incident,chg,cmdb snowNode
    class entra,kv secNode
    class appins,logana,alerts opsNode
    class pbi pbiNode
    class ops_eng,cam_mgr,app_own,fin_ops persona
